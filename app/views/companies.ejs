<%- include('layout/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Companies</h1>
  <a href="/companies/new" class="btn btn-dark">+ Add Company</a>
</div>

<div class="row g-3">
  <% companies.forEach(c => { %>
  <div class="col-md-6 col-lg-4">
    <div class="card h-100 p-3">
      <h5><a href="/companies/<%= c._id %>" class="text-decoration-none"><%= c.company_name %></a></h5>
      <p class="text-muted mb-1"><%= c.industry %> &middot; <%= c.company_size %></p>
      <p class="mb-1"><small><%= c.headquarters_location %></small></p>
      <p class="mb-0"><span class="badge bg-secondary"><%= c.job_listings ? c.job_listings.length : 0 %> listings</span></p>
    </div>
  </div>
  <% }) %>
</div>

<%- include('layout/footer') %>
