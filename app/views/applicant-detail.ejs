<%- include('layout/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= applicant.username %></h1>
  <div>
    <a href="/applicants/<%= applicant._id %>/edit" class="btn btn-outline-secondary btn-sm">Edit</a>
    <form action="/applicants/<%= applicant._id %>?_method=DELETE" method="POST" class="d-inline"
          onsubmit="return confirm('Delete this applicant?')">
      <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
    </form>
  </div>
</div>

<div class="card p-3 mb-4">
  <div class="row">
    <div class="col-md-6">
      <p><strong>Email:</strong> <%= applicant.email %></p>
      <p><strong>University:</strong> <%= applicant.university %></p>
      <p><strong>Degree:</strong> <%= applicant.degree_level %> &middot; Class of <%= applicant.graduation_year %></p>
    </div>
    <div class="col-md-6">
      <p><strong>GPA:</strong> <%= applicant.gpa.toFixed(2) %></p>
      <p><strong>Experience:</strong> <%= applicant.years_of_experience %> year(s)</p>
      <p><strong>Anonymized:</strong> <%= applicant.is_anonymized ? 'Yes' : 'No' %></p>
    </div>
  </div>
</div>

<h3>Skills (<%= applicant.skills ? applicant.skills.length : 0 %>)</h3>
<% if (applicant.skills && applicant.skills.length > 0) { %>
  <div class="d-flex flex-wrap gap-2 mb-4">
    <% applicant.skills.forEach(s => { %>
      <span class="badge bg-dark">
        <%= s.skill_name %>
        <small class="opacity-75">(<%= s.proficiency_level %>, <%= s.years_used %>yr)</small>
      </span>
    <% }) %>
  </div>
<% } else { %>
  <p class="text-muted mb-4">No skills listed.</p>
<% } %>

<h3>Applications (<%= applicant.applications ? applicant.applications.length : 0 %>)</h3>
<% if (applicant.applications && applicant.applications.length > 0) { %>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead class="table-dark">
        <tr>
          <th>Company</th>
          <th>Position</th>
          <th>Applied</th>
          <th>Status</th>
          <th>Salary</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% applicant.applications.forEach(app => { %>
        <tr>
          <td><%= app.company_name %></td>
          <td><%= app.listing_title %></td>
          <td><%= app.applied_date %></td>
          <td>
            <% if (app.status === 'accepted') { %>
              <span class="badge badge-accepted">Accepted</span>
            <% } else if (app.status === 'rejected') { %>
              <span class="badge badge-rejected">Rejected (<%= app.rejection_stage %>)</span>
            <% } else if (app.status === 'applied') { %>
              <span class="badge badge-applied">In Progress</span>
            <% } else { %>
              <span class="badge badge-withdrawn">Withdrawn</span>
            <% } %>
          </td>
          <td><%= app.offer_salary ? '$' + app.offer_salary.toLocaleString() : '—' %></td>
          <td><small class="text-muted"><%= app.notes || '' %></small></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <p class="text-muted">No applications yet.</p>
<% } %>

<a href="/applicants" class="btn btn-outline-dark mt-3">&larr; Back to Applicants</a>

<%- include('layout/footer') %>
